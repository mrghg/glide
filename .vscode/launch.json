{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "GLIDE: lpdm.main (Local Sample Met)",
            "type": "debugpy",
            "request": "launch",
            "module": "lpdm.main",
            "python": "${workspaceFolder}/.venv/bin/python",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "--config",
                "${workspaceFolder}/configs/local_smoke_test.yaml"
            ]
        },
        {
            "name": "GLIDE: lpdm.main (FLEXPART comparison)",
            "type": "debugpy",
            "request": "launch",
            "module": "lpdm.main",
            "python": "${workspaceFolder}/.venv/bin/python",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "--config",
                "${workspaceFolder}/configs/example_mhd_january.yaml"
            ]
        },
        {
            "name": "GLIDE: Current File (UV)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}
