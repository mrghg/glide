# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Build and packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Test and type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Local outputs/artifacts. `/outputs` (no trailing slash) matches both a real
# directory and the symlink-to-storage some devs use, so neither is committed.
/outputs
*.zarr/
*.nc
*.parquet

# SLURM run logs (personal run artifacts)
/slurm_logs/

# Personal SLURM-log helper scripts (untracked dev convenience; ignore if present)
/scripts/glogs.sh
/scripts/logcleanup
/scripts/loglatest

# Restricted / third-party data (not redistributed; see data/README.md).
# Ignore the data itself but keep the folder structure, README, and placeholders.
data/**
!data/README.md
!data/*/
!data/**/.gitkeep

# OS/editor noise
.DS_Store
.vscode/settings.json
